# Gemini API Key from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=

# Google Cloud API Key with Text-to-Speech API enabled (optional, falls back to GEMINI_API_KEY)
TTS_API_KEY=

# Basic Authentication credentials for the Vercel frontend
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Shared secret between the Vercel frontend and Railway backend
SHARED_SECRET=

