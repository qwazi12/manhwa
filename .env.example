# Gemini API Key from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=

# Google Cloud API Key with Text-to-Speech API enabled (optional, falls back to GEMINI_API_KEY)
TTS_API_KEY=

# Shared-secret access gate for the review server (server.py).
# If set, EVERY route (/api, /clip, /thumb, /audio, /panelimg, /export, /) requires
# the secret, supplied as an X-Auth-Token header, an auth_token cookie, or HTTP
# Basic auth (curl -u <user>:<secret>). If LEFT BLANK the server is UNAUTHENTICATED
# (fine for local dev / the offline pipeline; MUST be set on any public deployment).
RECAP_AUTH_TOKEN=
# Username shown for HTTP Basic auth (cosmetic; the password is RECAP_AUTH_TOKEN).
RECAP_AUTH_USER=recap
